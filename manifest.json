{
  "manifest_version": 3,
  "name": "Smart Dictionary Pro",
  "version": "6.0.0",
  "description": "Advanced dictionary and translator with Merriam-Webster Collegiate and MyMemory Translation API",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://www.dictionaryapi.com/*",
    "https://api.dictionaryapi.dev/*",
    "https://api.mymemory.translated.net/*"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "smart-dict-pro@yourname.com",
      "strict_min_version": "109.0"
    }
  },
  "icons": {
    "48": "icon.png",
    "128": "icon.png"
  }
}
